    <geom name="div_r1_r5"  type="box" pos="0.1296 0.2644 0.043" size="0.0546 0.0012 0.004" rgba="0.45 0.38 0.28 0.9"/>
    <!-- 세로 분할선: Region 1 ↔ Region 2/3  (x = 0.1842, y: 0.130~0.2644) -->
