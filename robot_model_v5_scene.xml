    <geom name="label_r2" type="cylinder" pos="0.2346 0.1748 0.054" size="0.012 0.004" rgba="0.20 0.40 0.80 1"/>
    <geom name="label_r3" type="cylinder" pos="0.2346 0.2644 0.054" size="0.012 0.004" rgba="0.55 0.20 0.75 1"/>
    <geom name="label_r4" type="cylinder" pos="0.2346 0.3596 0.054" size="0.012 0.004" rgba="0.80 0.50 0.05 1"/>
    <geom name="label_r5" type="cylinder" pos="0.1296 0.3372 0.054" size="0.012 0.004" rgba="0.80 0.20 0.20 1"/>

    <!-- ================================================================ -->
    <!--  v5: 입(Mouth) 위치 마커 — XML에서 제거됨.                          -->
    <!--                                                                    -->
    <!--  Mouth 위치는 (x=0, y=0.26, z∈[0.3,0.6])에서 실시간으로 IK가       -->
    <!--  최적 z를 선택하므로, 정적 XML 마커 대신 SequenceRunner가          -->
    <!--  viewer user_scn에 동적으로 핑크 구 마커를 그린다.                  -->
    <!--  (구버전 mouth_sphere/mouth_site/mouth_pole 제거.)                  -->
    <!-- ================================================================ -->

    <!-- ================================================================ -->
