    </body>

    <!-- ================================================================ -->
    <!--  식판 (Tray)                                                       -->
    <!--                                                                    -->
    <!--  좌표계 (world frame 기준)                                          -->
    <!--    식판 원점(우측 하단): x=0.075, y=0.130                          -->
