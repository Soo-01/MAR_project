    <geom name="tray_edge_right"  type="box" pos=" 0.287 0.270 0.043" size="0.002 0.142 0.007" rgba="0.60 0.52 0.42 1"/>

    <!-- ── 5개 Region 컬러 오버레이 (반투명, 식판 표면 위) ── -->
    <!--
        Region 배치 (tray frame → world frame):
          1 rice/main : tray x[0.000~0.1092] y[0.000~0.1344]  →  world x[0.075~0.1842] y[0.130~0.2644]
          2 side_1    : tray x[0.1092~0.210] y[0.000~0.0896]  →  world x[0.1842~0.285] y[0.130~0.2196]
          3 side_2    : tray x[0.1092~0.210] y[0.0896~0.1792]  →  world x[0.1842~0.285] y[0.2196~0.3092]
          4 side_3    : tray x[0.1092~0.210] y[0.1792~0.280]  →  world x[0.1842~0.285] y[0.3092~0.410]
          5 soup      : tray x[0.000~0.1092] y[0.1344~0.280]  →  world x[0.075~0.1842] y[0.2644~0.410]
    -->

    <!-- Region 1: rice / main  (연두색) -->
    <geom name="region1_overlay" type="box"
          pos="0.1296 0.1972 0.0418" size="0.0546 0.0672 0.0018"
          rgba="0.35 0.78 0.35 0.55"/>

    <!-- Region 2: side_1       (하늘색) -->
