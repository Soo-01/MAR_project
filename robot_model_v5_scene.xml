    <!--  높이 25 mm, 두께 6 mm, 갈색  -->
    <!--  Region 1 & 5: x=0.075 (식판 왼쪽 끝)  -->
    <!--  Region 2,3,4: x=0.1842 (좌우 중앙 분리선)  -->

    <!-- Region 1 barrier -->
    <geom name="barrier_r1" type="box"
