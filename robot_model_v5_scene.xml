    <!--    식판 좌측 하단(+Y):   x=0.075, y=0.410                          -->
    <!--    식판 표면 z = 0.040                                              -->
    <!--    드래그 방향: -X (x 감소 방향, 로봇 쪽)                           -->
    <!-- ================================================================ -->

    <!-- 식판 판체 (베이지, 전체 40mm 두께) -->
    <!-- 중심: x=0.180  y=0.270  z=0.020  -->
    <!-- 크기: x±0.105  y±0.140  z±0.020  (표면 z=0.040) -->
    <geom name="tray_body" type="box"
          pos="0.180 0.270 0.020" size="0.105 0.140 0.020"
          rgba="0.82 0.74 0.62 1"/>

