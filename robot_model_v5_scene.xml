    <!-- 세로 분할선: Region 5 ↔ Region 3/4  (x = 0.1842, y: 0.2644~0.410) -->
    <geom name="div_left_right_upper" type="box" pos="0.1842 0.3372 0.043" size="0.0012 0.0728 0.004" rgba="0.45 0.38 0.28 0.9"/>
    <!-- 가로 분할선: Region 2 ↕ Region 3  (y = 0.2196, x: 0.1842~0.285) -->
